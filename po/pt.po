#: ui/MainWindow.glade:13
msgid "Simple hotspot application."
msgstr "Aplicação simples de hotspot."

#: ui/MainWindow.glade:173
msgid "Interface Name:"
msgstr "Nome da interface:"

#: ui/MainWindow.glade:188
msgid "Choose an interface name"
msgstr "Escolher um nome de interface"

#: ui/MainWindow.glade:213 ui/MainWindow.glade:311
msgid "Connection Name:"
msgstr "Nome da ligação:"

#: ui/MainWindow.glade:228 ui/MainWindow.glade:326
msgid "Enter hotspot name"
msgstr "Introduzir o nome do hotspot"

#: ui/MainWindow.glade:254 ui/MainWindow.glade:351
msgid "Password:"
msgstr "Palavra-passe:"

#: ui/MainWindow.glade:269 ui/MainWindow.glade:366
msgid "Enter at least 8 characters"
msgstr "Introduzir pelo menos 8 caracteres"

#: ui/MainWindow.glade:396
msgid "Security Type:"
msgstr "Tipo de segurança:"

#: ui/MainWindow.glade:462
msgid "No devices connected"
msgstr "Nenhum dispositivo ligado"

#: ui/MainWindow.glade:498
msgid "Connected Devices"
msgstr "Dispositivos ligados"

#: ui/MainWindow.glade:553 src/MainWindow.py:414 src/MainWindow.py:452
#: src/MainWindow.py:688 src/MainWindow.py:911
msgid "Create Hotspot"
msgstr "Criar hotspot"

#: ui/MainWindow.glade:571 ui/MainWindow.glade:1012 src/MainWindow.py:260
#: src/MainWindow.py:525 src/MainWindow.py:938
msgid "Pardus Hotspot"
msgstr "Hotspot Pardus"

#: ui/MainWindow.glade:639
msgid "Band Selection:"
msgstr "Seleção de banda:"

#: ui/MainWindow.glade:678
msgid "Encryption Method:"
msgstr "Método de encriptação:"

#: ui/MainWindow.glade:690
msgid ""
"For Apple products, select  SAE . If the connection isn’t visible on other "
"devices, try switching to WPA-PSK\n"
msgstr ""
"Para produtos Apple, selecione SAE . Se a ligação não for visível noutros "
"dispositivos, experimente mudar para WPA-PSK\n"

#: ui/MainWindow.glade:718
msgid "Launch at Startup:"
msgstr "Iniciar no arranque:"

#: ui/MainWindow.glade:731
msgid "App auto-starts on every reboot"
msgstr "A aplicação inicia automaticamente em cada reiniciar"

#: ui/MainWindow.glade:759
msgid "IP Forwarding Enable:"
msgstr "Ativar o reencaminhamento de IP:"

#: ui/MainWindow.glade:772
msgid "IP forwarding requires root privileges"
msgstr "O reencaminhamento de IP requer privilégios root"

#: ui/MainWindow.glade:824 src/MainWindow.py:513 src/MainWindow.py:514
msgid "Home Page"
msgstr "Página inicial"

#: ui/MainWindow.glade:872
msgid "Restore Defaults"
msgstr "Repor predefinições"

