#: src/MainWindow.py:523 src/MainWindow.py:524 src/MainWindow.py:942
#: src/MainWindow.py:943
msgid "Settings"
msgstr "Definições"

#: ui/MainWindow.glade:948
msgid "Add to Group"
msgstr "Adicionar ao grupo"

#: ui/MainWindow.glade:973
msgid "OK"
msgstr "OK"

#: ui/MainWindow.glade:1002
msgid "Error"
msgstr "Erro"

#: ui/MainWindow.glade:1129
msgid "About"
msgstr "Acerca"

#: src/MainWindow.py:266 src/MainWindow.py:293 src/MainWindow.py:302
#: src/MainWindow.py:310
msgid "Show App"
msgstr "Mostrar aplicação"

#: src/MainWindow.py:272 src/MainWindow.py:415 src/MainWindow.py:689
msgid "Enable"
msgstr "Ativar"

#: src/MainWindow.py:278
msgid "Quit"
msgstr "Sair"

#: src/MainWindow.py:295 src/MainWindow.py:305 src/MainWindow.py:531
msgid "Hide App"
msgstr "Ocultar aplicação"

#: src/MainWindow.py:382 src/MainWindow.py:462 src/MainWindow.py:496
#: src/MainWindow.py:684 src/MainWindow.py:803
msgid "Disable Connection"
msgstr "Desativar ligação"

#: src/MainWindow.py:383 src/MainWindow.py:804
msgid "Disable"
msgstr "Desativar"

#: src/MainWindow.py:528
msgid "Hotspot Settings"
msgstr "Definições do Hotspot"

#: src/MainWindow.py:729 src/MainWindow.py:878
msgid "You need to reboot your system for group permissions to take effect."
msgstr ""
"É necessário reiniciar o sistema para que as permissões de grupo entrem em "
"vigor."

#: src/MainWindow.py:734
msgid "Network Permission Error"
msgstr "Erro de permissão de rede"

#: src/MainWindow.py:735
msgid "You don't have permission to modify network settings."
msgstr "Não tem permissão para alterar as definições de rede."

#: src/MainWindow.py:736
msgid "User is not in netdev group."
msgstr "O utilizador não pertence ao grupo netdev."

#: src/MainWindow.py:743
msgid "Please enable Wi-Fi to continue"
msgstr "Ativar o Wi-Fi para continuar"

#: src/MainWindow.py:752
msgid "Please select a network interface for the hotspot"
msgstr "Selecionar uma interface de rede para o hotspot"

#: src/MainWindow.py:761
msgid "Please enter a name for your hotspot connection"
msgstr "Introduzir um nome para a sua ligação hotspot"

#: src/MainWindow.py:770
msgid "Password must be at least 8 characters long"
msgstr "A palavra-passe deve ter pelo menos 8 caracteres"

#: src/MainWindow.py:858 src/MainWindow.py:887 src/MainWindow.py:893
msgid "Failed to add user to the netdev group."
msgstr "Não foi possível adicionar o utilizador ao grupo netdev."

#: src/MainWindow.py:877
msgid "User has been added to the netdev group."
msgstr "O utilizador foi adicionado ao grupo netdev."

#: src/network_utils.py:36
msgid "No wireless interfaces available"
msgstr "Não existem interfaces sem fios disponíveis"

#: src/network_utils.py:42
msgid "Wi-Fi Network Interface Not Found"
msgstr "Interface de rede Wi-Fi não encontrada"

#: src/network_utils.py:45
msgid ""
"Please ensure your computer has a Wi-Fi adapter and it is working correctly."
msgstr ""
"Certifique-se de que o computador tem um adaptador Wi-Fi e que este está a "
"funcionar corretamente."
