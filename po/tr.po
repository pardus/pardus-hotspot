msgid "Settings"
msgstr "Ayarlar"

#: ui/MainWindow.glade:948
msgid "Add to Group"
msgstr "Gruba Ekle"

#: ui/MainWindow.glade:973
msgid "OK"
msgstr "Tamam"

#: ui/MainWindow.glade:1002
msgid "Error"
msgstr "Hata"

#: ui/MainWindow.glade:1129
msgid "About"
msgstr "Hakkında"

#: src/MainWindow.py:266 src/MainWindow.py:293 src/MainWindow.py:302
#: src/MainWindow.py:310
msgid "Show App"
msgstr "Göster"

#: src/MainWindow.py:272 src/MainWindow.py:415 src/MainWindow.py:751
msgid "Enable"
msgstr "Etkinleştir"

#: src/MainWindow.py:278
msgid "Quit"
msgstr "Çıkış"

#: src/MainWindow.py:295 src/MainWindow.py:305 src/MainWindow.py:531
msgid "Hide App"
msgstr "Gizle"

#: src/MainWindow.py:382 src/MainWindow.py:462 src/MainWindow.py:496
#: src/MainWindow.py:746 src/MainWindow.py:865
msgid "Disable Connection"
msgstr "Bağlantıyı Kapat"

#: src/MainWindow.py:383 src/MainWindow.py:866
msgid "Disable"
msgstr "Devre Dışı Bırak"

#: src/MainWindow.py:528
msgid "Hotspot Settings"
msgstr "Kablosuz Erişim Noktası Ayarları"

#: src/MainWindow.py:650 src/MainWindow.py:673
msgid "Disconnect device"
msgstr "Cihaz bağlantısını kes"

#: src/MainWindow.py:676
#, python-format
msgid "%s will be disconnected. Continue?"
msgstr "%s bağlantısı kesilecek. Devam edilsin mi?"

#: src/MainWindow.py:678
msgid "Cancel"
msgstr "İptal"

#: src/MainWindow.py:679
msgid "Disconnect"
msgstr "Bağlantıyı Kes"

#: src/MainWindow.py:699
msgid "Failed to disconnect device"
msgstr "Cihaz bağlantısı kesilemedi."

#: src/MainWindow.py:702
msgid "Could not disconnect {}."
msgstr "%s bağlantısı kesilemedi."

#: src/MainWindow.py:791 src/MainWindow.py:940
msgid "You need to reboot your system for group permissions to take effect."
msgstr ""
"Grup izinlerinin geçerli olması için sisteminizi yeniden başlatmanız "
"gerekiyor."

#: src/MainWindow.py:796
msgid "Network Permission Error"
msgstr "Ağ İzin Hatası"

#: src/MainWindow.py:797
msgid "You don't have permission to modify network settings."
msgstr "Ağ ayarlarını değiştirmek için izniniz yok."

#: src/MainWindow.py:798
msgid "User is not in netdev group."
msgstr "Kullanıcı netdev grubunda değil."

#: src/MainWindow.py:805
msgid "Please enable Wi-Fi to continue"
msgstr "Devam etmek için Wi-Fi açın"

#: src/MainWindow.py:814
msgid "Please select a network interface for the hotspot"
msgstr "Lütfen kablosuz erişim noktası için bir ağ arayüzü seçin"

#: src/MainWindow.py:823
msgid "Please enter a name for your hotspot connection"
msgstr "Lütfen kablosuz erişim noktanız için bir isim girin"

#: src/MainWindow.py:832
msgid "Password must be at least 8 characters long"
msgstr "Parola en az 8 karakter uzunluğunda olmalı"

#: src/MainWindow.py:920 src/MainWindow.py:949 src/MainWindow.py:955
msgid "Failed to add user to the netdev group."
msgstr "Kullanıcı netdev grubuna eklenemedi."

#: src/MainWindow.py:939
msgid "User has been added to the netdev group."
msgstr "Kullanıcı netdev grubuna eklendi."

#: src/network_utils.py:36
msgid "No wireless interfaces available"
msgstr "Kablosuz ağ arayüzü bulunamadı"

#: src/network_utils.py:42
msgid "Wi-Fi Network Interface Not Found"
msgstr "Kablosuz ağ kartı bulunamadı"

#: src/network_utils.py:45
msgid ""
"Please ensure your computer has a Wi-Fi adapter and it is working correctly."
msgstr ""
"Lütfen bilgisayarınızda bir Wi-Fi adaptörü olduğundan ve düzgün "
"çalıştığından emin olun."

